# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- AI brain (LOCAL Ollama only) ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b          # dev box (8GB RAM); use qwen2.5:14b on 16GB+ prod

# --- Active Directory (read-only) ---
AD_DOMAIN=corp.local
LDAP_SERVER=ldap://dc01.corp.local
LDAP_BIND_USER=CORP\svc-itagent
LDAP_BIND_PASS=

# --- Collectors ---
# Hosts to ping: comma-separated here, and/or one-per-line in data/nodes.txt
PING_TARGETS=127.0.0.1,8.8.8.8
PING_INTERVAL_SEC=45
PING_TIMEOUT_MS=1000
OFFLINE_ALERT_SEC=300            # node offline longer than this (work hours) => alert

# --- Storage ---
DB_PATH=./data/itagent.db

# --- IT-context tool server (what Open WebUI calls) ---
# Keep on 127.0.0.1 unless Open WebUI runs on another on-prem host. Never expose
# to the internet — this serves internal monitoring data.
TOOL_SERVER_HOST=127.0.0.1
TOOL_SERVER_PORT=8000

# --- Alerts (optional) ---
ALERT_LINE_TOKEN=
ALERT_TEAMS_WEBHOOK=
ALERT_EMAIL_SMTP=
